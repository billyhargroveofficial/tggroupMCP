{
  "name": "telegram-parilka-mcp",
  "version": "0.1.0",
  "description": "TypeScript MCP server for reading and replying in a Telegram group through MTProto.",
  "type": "module",
  "private": true,
  "bin": {
    "telegram-parilka-mcp": "./dist/index.js",
    "telegram-parilka-mcp-generate-session": "./dist/generate-session.js",
    "telegram-parilka-mcp-sync-daemon": "./dist/sync-daemon.js",
    "telegram-parilka-mcp-embed-index": "./dist/embed-index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "check:shell": "bash -n bin/telegram-parilka-mcp bin/telegram-parilka-mcp-check-build bin/telegram-parilka-mcp-sync-daemon bin/telegram-parilka-mcp-embed-index bin/telegram-parilka-mcp-generate-session",
    "test": "node --test --import tsx tests/*.test.ts",
    "smoke:mcp": "tsx scripts/smoke-mcp.ts",
    "smoke:mcp:wrapper": "tsx scripts/smoke-mcp.ts --wrapper",
    "secret-scan": "tsx scripts/secret-scan.ts",
    "dev": "tsx src/index.ts",
    "generate-session": "tsx src/generate-session.ts",
    "embed-once": "tsx src/embed-index.ts",
    "print-config": "tsx src/index.ts --print-config",
    "validate-config": "tsx src/index.ts --validate-config",
    "status": "tsx src/index.ts --status",
    "sync-once": "tsx src/sync-daemon.ts --once",
    "sync-daemon": "tsx src/sync-daemon.ts",
    "benchmark:vector": "tsx scripts/benchmark-vector-search.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "input": "^1.0.1",
    "telegram": "^2.26.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
