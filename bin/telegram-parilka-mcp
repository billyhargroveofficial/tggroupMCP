#!/usr/bin/env bash
set -euo pipefail
cd /root/telegram-parilka-mcp
if [[ -f /root/.config/telegram-mcp/.env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /root/.config/telegram-mcp/.env
  set +a
fi
if [[ -f /root/telegram-parilka-mcp/.env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /root/telegram-parilka-mcp/.env
  set +a
fi
export TELEGRAM_SESSION="${TELEGRAM_SESSION:-${TELEGRAM_SESSION_STRING_PERSONAL:-}}"
exec node /root/telegram-parilka-mcp/dist/index.js "$@"
