# Telegram API credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash

# Generate with: npm run generate-session
TELEGRAM_SESSION=
TELEGRAM_PHONE=+15551234567

# Парилка228 default chat id. Override or add comma-separated IDs/usernames.
TELEGRAM_DEFAULT_CHAT_ID=-1003179772905
TELEGRAM_ALLOWED_CHAT_IDS=-1003179772905

# Sending is live by default for this deployment. Set dry-run/default disable flags to preview only.
TELEGRAM_SEND_ENABLED=true
TELEGRAM_DRY_RUN_DEFAULT=false

# Local cache for sync_history/search/read_history.
TELEGRAM_DB_PATH=~/.telegram-parilka-mcp/messages.sqlite

# Sync/read safety.
TELEGRAM_HISTORY_BATCH_SIZE=100
TELEGRAM_MAX_SYNC_LIMIT=500000
TELEGRAM_FLOOD_WAIT_MAX_SLEEP_SEC=10

# Background cache warmer. Use npm run sync-daemon, systemd, or cron.
TELEGRAM_SYNC_INTERVAL_MS=60000
TELEGRAM_SYNC_RECENT_LIMIT=300
TELEGRAM_SYNC_BACKFILL_LIMIT=1000

# Outgoing throttling.
TELEGRAM_GLOBAL_CONCURRENCY=2
TELEGRAM_MAX_RUNNING_PER_CHAT=1
TELEGRAM_USER_COOLDOWN_MS=20000
TELEGRAM_MAX_QUEUE_PER_CHAT=25
TELEGRAM_MAX_SEND_CHARS=4096
