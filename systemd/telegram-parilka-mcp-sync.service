[Unit]
Description=Telegram Parilka MCP SQLite cache warmer
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=10min
StartLimitBurst=3

[Service]
Type=simple
WorkingDirectory=/root/telegram-parilka-mcp
ExecStart=/root/telegram-parilka-mcp/bin/telegram-parilka-mcp-sync-daemon
Restart=on-failure
RestartSec=30
Environment=HOME=/root

[Install]
WantedBy=default.target
